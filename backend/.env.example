# AutoApply AI - Environment Variables
# Copy this file to .env and fill in your actual credentials

# Server Port
PORT=5000

# Groq API Key (Primary AI provider - 500 requests/day free tier)
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (Used for OCR/Vision tasks only)
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP Configuration
# Note: You need to use an "App Password" if you have 2FA enabled
# Generate app password: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_NAME=Your Name

# Google Sheets Job Tracker (Optional)
# 1. Create a Google Sheet for tracking applications
# 2. Get the Sheet ID from URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
# 3. Create a Service Account: https://console.cloud.google.com/iam-admin/serviceaccounts
# 4. Download credentials JSON and save as "google-credentials.json" in backend folder
# 5. Share your Google Sheet with the service account email (found in credentials file)
GOOGLE_SHEET_ID=your_google_sheet_id_here
